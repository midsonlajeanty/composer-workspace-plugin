{
    "name": "midsonlajeanty/composer-workspace-plugin",
    "description": "Bun-style monorepo workspaces for Composer: auto-registered path repositories (no repositories blocks needed) and fan-out commands across every member.",
    "type": "composer-plugin",
    "license": "MIT",
    "keywords": [
        "composer",
        "plugin",
        "monorepo",
        "workspace",
        "workspaces",
        "path-repository"
    ],
    "authors": [
        {
            "name": "Louis Midson LAJEANTY",
            "email": "midsonlajeanty@proton.me"
        }
    ],
    "support": {
        "issues": "https://github.com/midsonlajeanty/composer-workspace-plugin/issues",
        "source": "https://github.com/midsonlajeanty/composer-workspace-plugin"
    },
    "require": {
        "php": "^8.3",
        "composer-plugin-api": "^2.3"
    },
    "require-dev": {
        "composer/composer": "^2.8",
        "laravel/pint": "^1.29",
        "mrpunyapal/peststan": "^0.2.10",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.4"
    },
    "scripts": {
        "refactor": "rector",
        "lint": "pint",
        "test:unit": "pest",
        "test:refactor": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi",
        "test": [
            "@test:unit",
            "@test:refactor",
            "@test:lint",
            "@test:types"
        ]
    },
    "autoload": {
        "psr-4": {
            "Mds\\Workspace\\": "src/"
        }
    },
    "extra": {
        "class": "Mds\\Workspace\\WorkspacePlugin",
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
